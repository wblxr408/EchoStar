# ============================================
# EchoStar Backend .gitignore
# ============================================

# 依赖目录
node_modules/

# 环境变量文件
.env
.env.local
.env.*.local

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 测试覆盖率
coverage/
.nyc_output/

# 构建输出
dist/
build/

# IDE 和编辑器
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 临时文件
tmp/
temp/
*.tmp

# 操作系统文件
Thumbs.db
desktop.ini

# 数据库文件
*.sqlite
*.db

# 上传文件（如果有）
uploads/
public/uploads/

# Redis dump
dump.rdb

# 备份文件
*.bak
*.backup

# 测试生成的文件（保留测试脚本，忽略生成的报告和记录）
test-config.json
测试文件清单.md
DOCKER_DATABASE_SETUP.md
docker-compose.yml
test-config.local.json

# 本地测试专用文件（限流绕过服务器，严禁提交）
src/server.no-limit.js
src/cluster.no-limit.js