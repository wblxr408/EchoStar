# 服务器配置
NODE_ENV=development
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=echostar
DB_USERNAME=postgres
DB_PASSWORD=123456
DB_LOGGING=false

# JWT 配置
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# 阿里云 OSS 配置
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET=echostar
OSS_REGION=oss-cn-beijing
OSS_HOST=https://echostar.oss-cn-beijing.aliyuncs.com

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DB=0

# 前端 URL
FRONTEND_URL=http://localhost:5173

# 日志级别
LOG_LEVEL=info

# RocketMQ 配置
ROCKETMQ_NAME_SERVER=localhost:9876
ROCKETMQ_PRODUCER_GROUP=echostar-story-producer
ROCKETMQ_CONSUMER_GROUP=echostar-story-consumer
ROCKETMQ_TOPIC=story-operation
ROCKETMQ_TIMEOUT=3000
ROCKETMQ_RETRY_TIMES=3
ROCKETMQ_CONSUME_THREAD_NUMS=4
ROCKETMQ_PULL_BATCH_SIZE=32

# 雪花ID 配置
SNOWFLAKE_WORKER_ID=1
SNOWFLAKE_DATACENTER_ID=1
