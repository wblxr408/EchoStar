import { ref, readonly } from 'vue';

/**
 * Toast 消息类型
 */
type ToastType = 'success' | 'error' | 'warning' | 'info';

/**
 * Toast 消息接口
 */
interface Toast {
  id: number;
  message: string;
  type: ToastType;
  visible: boolean;
}

/**
 * Confirm 对话框接口
 */
interface ConfirmDialog {
  message: string;
  resolve: (result: boolean) => void;
}

/**
 * Prompt 对话框接口
 */
interface PromptDialog {
  message: string;
  placeholder?: string;
  defaultValue?: string;
  resolve: (value: string | null) => void;
}

// ========== 全局响应式状态 ==========
const toasts = ref<Toast[]>([]);
const confirmDialog = ref<ConfirmDialog | null>(null);
const promptDialog = ref<PromptDialog | null>(null);

let toastId = 0;

// ========== Toast（替代 alert）==========

/**
 * 显示 Toast 消息
 * @param message 提示文本
 * @param type 类型
 * @param duration 自动关闭时间(ms)，0=不自动关闭
 * @returns Toast ID
 */
export function showToast(
  message: string, 
  type: ToastType = 'info', 
  duration = 2500
): number {
  const id = ++toastId;
  toasts.value.push({ id, message, type, visible: true });

  if (duration > 0) {
    setTimeout(() => removeToast(id), duration);
  }
  return id;
}

/**
 * 移除 Toast
 */
function removeToast(id: number): void {
  const idx = toasts.value.findIndex(t => t.id === id);
  if (idx !== -1) {
    toasts.value[idx].visible = false;
    // 等动画结束再移除
    setTimeout(() => {
      const i = toasts.value.findIndex(t => t.id === id);
      if (i !== -1) {
        toasts.value.splice(i, 1);
      }
    }, 300);
  }
}

/**
 * 清除所有 Toast
 */
export function clearAllToasts(): void {
  toasts.value = [];
}

// ========== 快捷方法 ==========

export const toast = {
  success: (message: string, duration?: number) => showToast(message, 'success', duration),
  error: (message: string, duration?: number) => showToast(message, 'error', duration),
  warning: (message: string, duration?: number) => showToast(message, 'warning', duration),
  info: (message: string, duration?: number) => showToast(message, 'info', duration),
};

// ========== Confirm（替代 confirm）==========

/**
 * 显示确认对话框
 * @param message 确认文本
 * @returns Promise<boolean>
 */
export function showConfirm(message: string): Promise<boolean> {
  return new Promise((resolve) => {
    confirmDialog.value = { message, resolve };
  });
}

/**
 * 处理确认结果
 */
export function handleConfirmResult(result: boolean): void {
  if (confirmDialog.value) {
    confirmDialog.value.resolve(result);
    confirmDialog.value = null;
  }
}

// ========== Prompt（替代 prompt）==========

/**
 * 显示输入对话框
 * @param message 提示文本
 * @param options 选项
 * @returns Promise<string|null>
 */
export function showPrompt(
  message: string, 
  options: { placeholder?: string; defaultValue?: string } = {}
): Promise<string | null> {
  return new Promise((resolve) => {
    promptDialog.value = { message, ...options, resolve };
  });
}

/**
 * 处理 Prompt 结果
 */
export function handlePromptResult(value: string | null): void {
  if (promptDialog.value) {
    promptDialog.value.resolve(value);
    promptDialog.value = null;
  }
}

// ========== Composable ==========

/**
 * useToast Composable
 * 提供 Toast、Confirm、Prompt 功能
 */
export function useToast() {
  return {
    // 状态（只读）
    toasts: readonly(toasts),
    confirmDialog: readonly(confirmDialog),
    promptDialog: readonly(promptDialog),
    
    // Toast 方法
    showToast,
    clearAllToasts,
    toast,
    
    // Confirm 方法
    showConfirm,
    handleConfirmResult,
    
    // Prompt 方法
    showPrompt,
    handlePromptResult,
  };
}

// 导出类型
export type { ToastType, Toast, ConfirmDialog, PromptDialog };
