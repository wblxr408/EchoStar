{
  "name": "echostar-frontend",
  "version": "1.0.0",
  "description": "EchoStar 前端应用 - 情绪地图社交应用",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/**/*.{js,vue}",
    "format": "prettier --write \"src/**/*.{js,vue,css,scss}\"",
    "generate:types": "openapi-typescript ../docs/openapi.yaml --output src/types/api.d.ts",
    "mock:api": "prism mock ../docs/openapi.yaml --port 4010"
  },
  "dependencies": {
    "ali-oss": "^6.18.1",
    "axios": "^1.6.2",
    "dompurify": "^3.3.3",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^4.7.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "eslint": "^8.55.0",
    "eslint-plugin-vue": "^9.19.2",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.1.1",
    "sass": "^1.69.5",
    "vite": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
